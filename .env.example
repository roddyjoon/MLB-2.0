# Copy to .env and fill in. .env is gitignored.

# Resend (https://resend.com/signup → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where the daily card emails go
CARD_RECIPIENT_EMAIL=rodkazazi@gmail.com

# Optional override of the From line. Default: "MLB v3 <onboarding@resend.dev>"
# Once you verify a domain on Resend, switch to your own (e.g. "MLB v3 <cards@yourdomain.com>")
# CARD_FROM_EMAIL=MLB v3 <cards@yourdomain.com>
